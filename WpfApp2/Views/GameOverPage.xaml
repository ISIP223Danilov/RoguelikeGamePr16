<UserControl x:Class="WpfApp2.Views.GameOverPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1a1a2e">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="💀 ИГРА ОКОНЧЕНА 💀" 
                       FontSize="48" 
                       FontWeight="Bold"
                       Foreground="#e94560"
                       TextAlignment="Center"/>
            <TextBlock Text="Вы пали в бою..." 
                       FontSize="24" 
                       Foreground="#c4c4c4"
                       TextAlignment="Center"
                       Margin="0,20,0,0"/>
            <TextBlock Text="Roguelike не прощает ошибок" 
                       FontSize="14" 
                       Foreground="#888888"
                       TextAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <Button Grid.Row="1" 
                Content="🔄 НАЧАТЬ ЗАНОВО"
                FontSize="24"
                FontWeight="Bold"
                Width="250"
                Height="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#e94560"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding RestartCommand}"/>
    </Grid>
</UserControl>