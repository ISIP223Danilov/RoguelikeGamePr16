<UserControl x:Class="WpfApp2.Views.StartMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1a1a2e">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="⚔️ DUNGEON CRAWLER ⚔️" 
                       FontSize="48" 
                       FontWeight="Bold"
                       Foreground="#e94560"
                       Margin="0,0,0,30"/>
            <TextBlock Text="Roguelike Adventure" 
                       FontSize="24" 
                       Foreground="#c4c4c4"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,50"/>
            <Button Content="▶ НАЧАТЬ ИГРУ"
                    FontSize="28"
                    FontWeight="Bold"
                    Width="300"
                    Height="80"
                    Background="#e94560"
                    Foreground="White"
                    Click="StartGameButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>