<UserControl x:Class="WpfApp2.Views.StartMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfApp2.ViewModels">

    <Grid Background="#1a1a2e">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="⚔️ DUNGEON CRAWLER ⚔️" 
                       FontSize="48" 
                       FontWeight="Bold"
                       Foreground="#e94560"
                       TextAlignment="Center"/>
            <TextBlock Text="Roguelike Adventure" 
                       FontSize="24" 
                       Foreground="#c4c4c4"
                       TextAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <Button Grid.Row="1" 
                Content="▶ НАЧАТЬ ИГРУ"
                FontSize="28"
                FontWeight="Bold"
                Width="300"
                Height="80"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#e94560"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding StartGameCommand}">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>

        <StackPanel Grid.Row="2" 
                    VerticalAlignment="Bottom" 
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30">
            <TextBlock Text="Пошаговая RPG с элементами roguelike" 
                       Foreground="#888888"
                       FontSize="14"/>
            <TextBlock Text="Босс каждые 10 этажей" 
                       Foreground="#888888"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>