<UserControl x:Class="WpfApp2.Views.GamePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfApp2.Views">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="#0f0f1a">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Верхняя панель персонажа -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" 
                Background="#1a1a2e" 
                Padding="15" 
                BorderBrush="#e94560" 
                BorderThickness="0,0,0,2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🗼 Этаж: " Foreground="#c4c4c4" FontSize="18"/>
                <TextBlock Text="{Binding Player.CurrentFloor}" Foreground="#e94560" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="    ❤️ Здоровье: " Foreground="#c4c4c4" FontSize="18"/>
                <TextBlock Text="{Binding Player.Health}" Foreground="#e94560" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="/" Foreground="#c4c4c4" FontSize="18"/>
                <TextBlock Text="{Binding Player.MaxHealth}" Foreground="#e94560" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="    ⚔️ Оружие: " Foreground="#c4c4c4" FontSize="18"/>
                <TextBlock Text="{Binding Player.CurrentWeapon.Name}" Foreground="#ffd700" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="    🛡️ Доспех: " Foreground="#c4c4c4" FontSize="18"/>
                <TextBlock Text="{Binding Player.CurrentArmor.Name}" Foreground="#4ecdc4" FontSize="18" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Основная область игры -->
        <Border Grid.Row="1" Grid.Column="0" Margin="20" 
                Background="#1a1a2e" 
                BorderBrush="#e94560" 
                BorderThickness="2" 
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Image Grid.Row="0" 
       x:Name="GameImage" 
       Width="200" 
       Height="200"
       HorizontalAlignment="Center" 
       VerticalAlignment="Center"
       Source="{Binding CurrentImage}"/>

                <Border Grid.Row="1" 
                        Background="#0f0f1a" 
                        Margin="10" 
                        Padding="10"
                        CornerRadius="5">
                    <TextBlock Text="{Binding EnemyInfo}" 
                               FontSize="16" 
                               Foreground="#c4c4c4"
                               TextAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Журнал событий -->
        <Border Grid.Row="1" Grid.Column="1" Margin="20,20,20,20" 
                Background="#1a1a2e" 
                BorderBrush="#e94560" 
                BorderThickness="2" 
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="📜 ЖУРНАЛ СОБЫТИЙ" 
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="#e94560"
                           HorizontalAlignment="Center"
                           Margin="10,5"/>

                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding Logger.Events}" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Margin="10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" 
                                       Foreground="#c4c4c4" 
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,3"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Инвентарь -->
        <Border Grid.Row="1" Grid.Column="1" Margin="20,20,20,20" 
                Background="#1a1a2e" 
                BorderBrush="#e94560" 
                BorderThickness="2" 
                CornerRadius="10"
                VerticalAlignment="Bottom"
                Height="200">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="🎒 ИНВЕНТАРЬ" 
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="#e94560"
                           HorizontalAlignment="Center"
                           Margin="10,5"/>

                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding InventoryItems}" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Margin="5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="{Binding Icon}" FontSize="20" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Foreground="#ffd700" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#888888" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Панель управления -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                Background="#1a1a2e" 
                Padding="15" 
                BorderBrush="#e94560" 
                BorderThickness="0,2,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⚔️ АТАКОВАТЬ" 
                        Width="150" 
                        Height="50" 
                        Margin="10"
                        Background="#e94560"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Command="{Binding AttackCommand}"/>

                <Button Content="🛡️ ЗАЩИТА" 
                        Width="150" 
                        Height="50" 
                        Margin="10"
                        Background="#4ecdc4"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Command="{Binding DefendCommand}"/>

                <Button Content="🔮 ДАЛЬШЕ" 
                        Width="150" 
                        Height="50" 
                        Margin="10"
                        Background="#ffd700"
                        Foreground="#1a1a2e"
                        FontSize="16"
                        FontWeight="Bold"
                        Command="{Binding NextTurnCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>