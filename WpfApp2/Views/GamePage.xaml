<UserControl x:Class="WpfApp2.Views.GamePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfApp2.ViewModels"
             xmlns:models="clr-namespace:WpfApp2.Models">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibility"/>

        <DataTemplate DataType="{x:Type models:Item}">
            <Border Background="#16213e" 
                    CornerRadius="5" 
                    Margin="5" 
                    Padding="10"
                    Cursor="Hand"
                    MouseLeftButtonDown="Item_MouseLeftButtonDown">
                <StackPanel>
                    <TextBlock Text="{Binding Icon}" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Name}" 
                               Foreground="#ffd700" 
                               FontSize="12" 
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Description}" 
                               Foreground="#888888" 
                               FontSize="10" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="#0f0f1a">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Верхняя панель персонажа -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" 
                Background="#1a1a2e" 
                Padding="15" 
                BorderBrush="#e94560" 
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🗼 Этаж: " Foreground="#c4c4c4" FontSize="18"/>
                    <TextBlock Text="{Binding Player.CurrentFloor}" Foreground="#e94560" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="❤️ Здоровье: " Foreground="#c4c4c4" FontSize="18"/>
                    <TextBlock Text="{Binding Player.Health}" Foreground="#e94560" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="/" Foreground="#c4c4c4" FontSize="18"/>
                    <TextBlock Text="{Binding Player.MaxHealth}" Foreground="#e94560" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚔️ Оружие: " Foreground="#c4c4c4" FontSize="18"/>
                    <TextBlock Text="{Binding Player.CurrentWeapon.Name}" Foreground="#ffd700" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text=" (" Foreground="#c4c4c4"/>
                    <TextBlock Text="{Binding Player.CurrentWeapon.Damage}" Foreground="#ffd700" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text=")" Foreground="#c4c4c4"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡️ Доспех: " Foreground="#c4c4c4" FontSize="18"/>
                    <TextBlock Text="{Binding Player.CurrentArmor.Name}" Foreground="#4ecdc4" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text=" (" Foreground="#c4c4c4"/>
                    <TextBlock Text="{Binding Player.CurrentArmor.Defense}" Foreground="#4ecdc4" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text=")" Foreground="#c4c4c4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область игры -->
        <Border Grid.Row="1" Grid.Column="0" Margin="20" 
                Background="#1a1a2e" 
                BorderBrush="#e94560" 
                BorderThickness="2" 
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Изображение врага/сундука -->
                <Border Grid.Row="0" Background="#16213e" CornerRadius="8" Margin="10">
                    <Image Source="{Binding CurrentImage}" 
                           Stretch="Uniform" 
                           Width="300" 
                           Height="300"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source" Value="/Images/placeholder.png"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentImage}" Value="{x:Null}">
                                        <Setter Property="Source" Value="/Images/placeholder.png"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Border>

                <!-- Информация о враге -->
                <Border Grid.Row="1" 
                        Background="#0f0f1a" 
                        Margin="10" 
                        Padding="10"
                        CornerRadius="5">
                    <TextBlock Text="{Binding EnemyInfo}" 
                               FontSize="16" 
                               Foreground="#c4c4c4"
                               TextAlignment="Center"
                               Visibility="{Binding IsInCombat, Converter={StaticResource BoolToVisibility}}"/>
                </Border>

                <!-- Оверлей выбора предмета -->
                <Border Grid.RowSpan="2" 
                        Background="#80000000" 
                        Visibility="{Binding ShowItemChoice, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="#1a1a2e" 
                                Padding="30" 
                                CornerRadius="10"
                                BorderBrush="#e94560"
                                BorderThickness="2">
                            <StackPanel>
                                <TextBlock Text="📦 Вы нашли предмет!" 
                                           FontSize="24" 
                                           Foreground="#e94560"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,20"/>
                                <TextBlock Text="{Binding PendingItem.Name}" 
                                           FontSize="20" 
                                           Foreground="#ffd700"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding PendingItem.Description}" 
                                           FontSize="14" 
                                           Foreground="#c4c4c4"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,20"/>
                                <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center" 
                                            Margin="0,20,0,0">
                                    <Button Content="✅ Взять" 
                                            Width="100" 
                                            Height="40" 
                                            Margin="10"
                                            Background="#4ecdc4"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Command="{Binding TakeItemCommand}"/>
                                    <Button Content="❌ Выбросить" 
                                            Width="100" 
                                            Height="40" 
                                            Margin="10"
                                            Background="#e94560"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Command="{Binding DiscardItemCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Панель событий и инвентаря -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="20,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Журнал событий -->
            <Border Grid.Row="0" Grid.RowSpan="2" 
                    Background="#1a1a2e" 
                    BorderBrush="#e94560" 
                    BorderThickness="2" 
                    CornerRadius="10"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="📜 ЖУРНАЛ СОБЫТИЙ" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="#e94560"
                               HorizontalAlignment="Center"
                               Margin="10,5"/>

                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Logger.Events}" 
                             Background="Transparent" 
                             BorderThickness="0"
                             Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                           Foreground="#c4c4c4" 
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Инвентарь -->
            <Border Grid.Row="2" Grid.RowSpan="2" 
                    Background="#1a1a2e" 
                    BorderBrush="#e94560" 
                    BorderThickness="2" 
                    CornernerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="🎒 ИНВЕНТАРЬ" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="#e94560"
                               HorizontalAlignment="Center"
                               Margin="10,5"/>

                    <ScrollViewer Grid.Row="1" Margin="5">
                        <ItemsControl ItemsSource="{Binding InventoryItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Панель управления -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                Background="#1a1a2e" 
                Padding="15" 
                BorderBrush="#e94560" 
                BorderThickness="0,2,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⚔️ АТАКОВАТЬ" 
                        Width="150" 
                        Height="50" 
                        Margin="10"
                        Background="#e94560"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Command="{Binding AttackCommand}"
                        Visibility="{Binding IsInCombat, Converter={StaticResource BoolToVisibility}}"/>

                <Button Content="🛡️ ЗАЩИТА" 
                        Width="150" 
                        Height="50" 
                        Margin="10"
                        Background="#4ecdc4"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Command="{Binding DefendCommand}"
                        Visibility="{Binding IsInCombat, Converter={StaticResource BoolToVisibility}}"/>

                <Button Content="🔮 ДАЛЬШЕ" 
                        Width="150" 
                        Height="50" 
                        Margin="10"
                        Background="#ffd700"
                        Foreground="#1a1a2e"
                        FontSize="16"
                        FontWeight="Bold"
                        Command="{Binding NextTurnCommand}"
                        Visibility="{Binding IsInCombat, Converter={StaticResource InvertedBoolToVisibility}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>